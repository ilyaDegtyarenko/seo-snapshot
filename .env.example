# Path to the config file (alternative to --config flag)
# SEO_SNAPSHOT_CONFIG_PATH=config/seo-snapshot.config.mjs

# Full config as a JSON object (overrides config file)
# SEO_SNAPSHOT_CONFIG={"baseUrl":"http://localhost:3000","targets":["/"]}

# Overrides for individual config fields
# SEO_SNAPSHOT_BASE_URL=http://localhost:3000
# SEO_SNAPSHOT_BASE_URL='{"url":"https://example.com","label":"prod"}'
# SEO_SNAPSHOT_COMPARE_URL=https://stage.example.com
# SEO_SNAPSHOT_COMPARE_URL={"url":"https://stage.example.com","label":"stage"}
# SEO_SNAPSHOT_TARGETS_FILE=./targets.json
# SEO_SNAPSHOT_TARGETS=/,/about,/news
# SEO_SNAPSHOT_OUTPUT_DIR=reports
# SEO_SNAPSHOT_OUTPUT_FORMATS=html,json
# SEO_SNAPSHOT_OUTPUT_HIDE_TTFB=true
# SEO_SNAPSHOT_OUTPUT_HIDE_PRELOAD_LINKS=true
# SEO_SNAPSHOT_OUTPUT_HIDE_PRECONNECT_LINKS=true
# SEO_SNAPSHOT_OUTPUT_HIDE_DNS_PREFETCH_LINKS=true
# SEO_SNAPSHOT_OUTPUT_COMPRESS=true
# SEO_SNAPSHOT_OUTPUT_MINIFY=false
# SEO_SNAPSHOT_OPEN=true
# SEO_SNAPSHOT_PROFILE=staging

# Request settings
# SEO_SNAPSHOT_REQUEST_TIMEOUT_MS=15000
# SEO_SNAPSHOT_REQUEST_MAX_REDIRECTS=10
# SEO_SNAPSHOT_REQUEST_CONCURRENCY=4
# SEO_SNAPSHOT_REQUEST_USER_AGENT=Mozilla/5.0 (compatible; SEO-Snapshot/1.0)
# SEO_SNAPSHOT_REQUEST_USER_AGENT=[{"label":"Desktop","userAgent":"Mozilla/5.0 (Macintosh...)"},{"label":"Mobile","userAgent":"Mozilla/5.0 (iPhone...)"}]
# SEO_SNAPSHOT_REQUEST_COOKIES=session=abc123; token=xyz
# SEO_SNAPSHOT_REQUEST_COOKIES={"session":"abc123","token":"xyz"}
# SEO_SNAPSHOT_REQUEST_HEADERS={"Authorization":"Bearer token","X-Custom":"value"}

# Audit thresholds
# SEO_SNAPSHOT_AUDIT_MIN_TITLE_LENGTH=15
# SEO_SNAPSHOT_AUDIT_MAX_TITLE_LENGTH=60
# SEO_SNAPSHOT_AUDIT_MIN_DESCRIPTION_LENGTH=70
# SEO_SNAPSHOT_AUDIT_MAX_DESCRIPTION_LENGTH=160
# SEO_SNAPSHOT_AUDIT_MIN_BODY_TEXT_LENGTH=250
# SEO_SNAPSHOT_AUDIT_FLAG_EMPTY_ALT=true
# SEO_SNAPSHOT_AUDIT_IGNORE=missing_twitter_card,missing_og_image
# SEO_SNAPSHOT_AUDIT_IGNORE=["missing_twitter_card","missing_og_image"]
